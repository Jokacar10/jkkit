# Required for Tonstakers; recommended for everything else.
# Get a free key at https://toncenter.com.
VITE_TONCENTER_API_KEY=

# Override the TonConnect manifest URL. Defaults to a public demo manifest.
# For prod, host your own at /tonconnect-manifest.json.
# VITE_TONCONNECT_MANIFEST_URL=https://your-app.example.com/tonconnect-manifest.json
